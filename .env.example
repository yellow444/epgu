# Шаблон переменных окружения. Скопируйте в .env и заполните под свою среду.
# Полное описание — docs/api.md#переменные-окружения и docs/SERVICES.md.

# ---------- Криптография ----------
# GUID API-ключа организации, выпущенный на технологическом портале ЕСИА
apikey=00000000-0000-0000-0000-000000000000
# PIN контейнера КриптоПро (в проде — через secrets/Vault, не env)
KeyPin=1234567890
# TSA для CAdES-T. Тест: http://testca2012.cryptopro.ru/tsp/tsp.srf
TSAAddress=http://www.cryptopro.ru/tsp/tsp.srf
# Папка с контейнером ключа (xxx.000)
key_folder=./api-gosuslugi-backend/xxx.000

# ---------- Среды ----------
# ТЕСТ (SVCDEV):
esia_host=https://esia-portal1.test.gosuslugi.ru
svcdev_host=https://svcdev-beta.test.gosuslugi.ru
# ПРОД (ГОСТ TLS):
#esia_host=https://esia.gosuslugi.ru
#svcdev_host=https://lk.gosuslugi.ru

# ---------- Режим ----------
# production=1 — отключает debugpy, уровень логов INFO. Оставьте пустым для dev.
production=

# ---------- Frontend / proxy ----------
BACKEND_URL=/api
BACKEND_API=http://api:5000

# ---------- Безопасность ----------
# CORS allow_origins. Список через запятую или "*".
# В проде укажите конкретный домен фронтенда.
ALLOWED_ORIGINS=*

# ---------- Каталог услуг ----------
# JSON-объект code → {description, req_file, piev_epgu_file, region, targetCode, eServiceCode, serviceTargetCode}.
# Если переменная пустая — используется DEFAULT_SERVICES из api-gosuslugi-backend/config.py.
# Полный каталог — docs/SERVICES.md.
SERVICES=

# Пример (одна услуга):
#SERVICES={"60010153":{"description":"Наличие ИП (ФССП)","req_file":"req.xml","piev_epgu_file":"piev_epgu.xml","region":"45000000000","targetCode":"-60010153","eServiceCode":"60010153","serviceTargetCode":"-60010153"}}
